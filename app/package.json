{
  "name": "wordplay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:single": "tsc --noEmit && vite build --mode single",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "sync-data": "node scripts/sync-data.mjs",
    "build-lexicon": "node scripts/build-lexicon.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^3.0.0"
  }
}
